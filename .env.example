# --- Supabase ---
# Project URL and public anon key: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key: ONLY used server-side (e.g. audit tooling, migrations).
# Never expose to the browser. Not used by the theme feature itself, since
# that relies on RLS + the staff_users allow-list instead.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://www.iconos-group.com

# --- Cloudflare Turnstile (contact form bot protection) ---
# Create a widget at https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Email delivery (contact form) — Microsoft Graph ---
# Sent from a dedicated Azure AD app registration (separate from the SSO
# one) with an application-level Mail.Send permission, scoped via an
# Exchange Online Application Access Policy to ONLY the sender mailbox
# below. See README "Contact form: Turnstile + Microsoft Graph mail".
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_SENDER_MAILBOX=enquiries@iconos-group.com
CONTACT_TO_EMAIL=legal@iconos-group.com
